{
  "rewrites": [
    { "source": "/api/test", "destination": "/api/test.js" },
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/share/blog/:id", "destination": "/api/index.js" },
    { "source": "/share/testimonials/:id", "destination": "/api/index.js" },
    { "source": "/share/forum/:id", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/google1801069cb5a6ae0c.html",
      "headers": [{ "key": "Content-Type", "value": "text/html" }]
    }
  ]
}
